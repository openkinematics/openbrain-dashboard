# Copy to .env.local and fill in. All NEXT_PUBLIC_* values are inlined at build time.

# ── Robot endpoints ──────────────────────────────────────────────────────────
# rosbridge WebSocket — the operator can override per-robot from Profile/Fleet.
NEXT_PUBLIC_ROSBRIDGE_URL=ws://localhost:9090

# WebRTC + MJPEG video streamer base (openbrain-ros HTTP server).
NEXT_PUBLIC_VIDEO_BASE_URL=http://localhost:8080

# ── WebRTC ICE servers ──────────────────────────────────────────────────────
# Comma-separated. Defaults to a single Google STUN if unset.
# NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302
# Required for peers behind symmetric NAT — without TURN, those clients fall back to MJPEG.
# NEXT_PUBLIC_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# ── Branding / SEO ───────────────────────────────────────────────────────────
# Public origin used by sitemap.xml, robots.txt, and OG metadata.
# NEXT_PUBLIC_DEPLOYMENT_URL=https://dashboard.openkinematics.com

# Camera tile "no signal" / loading backdrop image (optional).
# NEXT_PUBLIC_CAMERA_NO_SIGNAL_POSTER_URL=https://example.com/poster.jpg
