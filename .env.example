# Copy to .env.local and fill in.

# Robot connection — rosbridge WebSocket
NEXT_PUBLIC_ROSBRIDGE_URL=ws://localhost:9090

# WebRTC video streamer (the openbrain-ros HTTP server)
NEXT_PUBLIC_VIDEO_BASE_URL=http://localhost:8080

# Camera tile “no signal” / loading backdrop image (optional)
# NEXT_PUBLIC_CAMERA_NO_SIGNAL_POSTER_URL=https://example.com/poster.jpg
