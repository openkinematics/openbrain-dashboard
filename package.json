{
  "name": "openbrain-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "OpenBrain — Next.js operator dashboard for robots running openbrain-ros (teleop, maps, missions, health, fleet).",
  "license": "MIT",
  "homepage": "https://www.openkinematics.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/openkinematics/openbrain-dashboard"
  },
  "bugs": {
    "url": "https://github.com/openkinematics/openbrain-dashboard/issues"
  },
  "keywords": [
    "openbrain",
    "openbrain-ros",
    "openkinematics",
    "robotics",
    "ros2",
    "dashboard",
    "nextjs"
  ],
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.13",
      "uuid": "14.0.0"
    }
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=1 next build --webpack",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-grid-layout": "^2.2.3",
    "recharts": "^3.8.1",
    "roslib": "^2.1.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "urdf-loader": "^0.12.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "happy-dom": "^15.11.7",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
